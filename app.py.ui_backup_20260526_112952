# ─── Module loader ────────────────────────────────────────────────────────────
def show_module(pid):
    try:
        mod = importlib.import_module(f"modules.{pid}")
        mod.show()
    except ModuleNotFoundError as e:
        st.error(f"Chưa tìm thấy module `modules/{pid}.py`. Chi tiết: {e}")
    except Exception as e:
        import traceback
        st.error(f"Lỗi trong module **{pid}**: `{e}`")
        with st.expander("Chi tiết lỗi"):
            st.code(traceback.format_exc())


# ─── Router ───────────────────────────────────────────────────────────────────
